# ---- Database (Docker Postgres) ----
POSTGRES_USER=panditas
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=panditas_wallet
POSTGRES_PORT=5432
DATABASE_URL=postgresql://panditas:change-me-locally@localhost:5432/panditas_wallet?schema=public

# ---- Branding ----
# Display name shown in the nav/title (web) and email subjects (api).
# Set both to the same value if you rename this for a different household.
VITE_APP_NAME=Panditas Wallet
APP_NAME=Panditas Wallet

# ---- API ----
# Dev uses 4000; the LAN launcher runs the single-port server on 80.
API_PORT=4000
# 0.0.0.0 exposes it on the LAN (all interfaces); 127.0.0.1 keeps it Mac-only.
API_HOST=0.0.0.0
# Comma-separated origins allowed to call the API in dev (the Vite server).
CORS_ORIGINS=http://localhost:5173
# When true, the API also serves the built web app on the same port (LAN/NAS deploy).
SERVE_WEB=false

# ---- Auth ----
# Long random string used to sign session cookies. Generate: openssl rand -hex 32
SESSION_SECRET=replace-with-openssl-rand-hex-32

# ---- Encryption at rest ----
# 32-byte key (hex) for AES-256-GCM field encryption of SimpleFIN tokens.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# ---- Sync ----
# Cron expression for the background SimpleFIN sync (while the machine is awake).
SYNC_CRON=0 */6 * * *

# ---- Seed (used only by `pnpm db:seed`) ----
# The seed requires these; there is no default password baked into source.
SEED_ADMIN_NAME=Your Name
SEED_ADMIN_EMAIL=you@example.com
SEED_ADMIN_PASSWORD=set-a-strong-password

# ---- Web (dev only) ----
# Where the Vite dev server proxies /api to. Not used by the built app (relative).
API_PROXY_TARGET=http://localhost:4000

# ---- Email notifications (SimpleFIN reconnect alerts) ----
# Optional — if unset, notifications are skipped (logged, not fatal).
# Gmail: use an App Password (myaccount.google.com/apppasswords), not your real password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=you@gmail.com
# Defaults to the seeded admin's email (SEED_ADMIN_EMAIL) if unset.
NOTIFY_EMAIL_TO=
# Used only to build the link in notification emails, e.g. http://panditas.local
APP_URL=

# ---- Periodic finance summary email (week/quarter/half/year, to all adults) ----
# Unset by default — this is new, unverified content going to every adult's
# inbox, so it doesn't turn on just because SMTP above is configured.
# Uncomment once you've reviewed the format (see docs/TODOIdeas.md item 1/2):
# SUMMARY_CRON=0 8 * * *
